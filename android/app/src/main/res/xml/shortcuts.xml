<?xml version="1.0" encoding="utf-8"?>
<!--
  Android App Shortcuts Configuration
  These static shortcuts appear when long-pressing the app icon.
  
  Note: When building with Expo, use a config plugin to inject this file.
  For bare workflow, place in android/app/src/main/res/xml/shortcuts.xml
-->
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- New Message Shortcut -->
    <shortcut
        android:shortcutId="new_message"
        android:enabled="true"
        android:icon="@drawable/ic_shortcut_compose"
        android:shortcutShortLabel="@string/shortcut_new_message_short"
        android:shortcutLongLabel="@string/shortcut_new_message_long"
        android:shortcutDisabledMessage="@string/shortcut_disabled">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="io.hearth.mobile"
            android:targetClass="io.hearth.mobile.MainActivity"
            android:data="hearth://new-message" />
        <categories android:name="android.shortcut.conversation" />
    </shortcut>
    
    <!-- Search Shortcut -->
    <shortcut
        android:shortcutId="search"
        android:enabled="true"
        android:icon="@drawable/ic_shortcut_search"
        android:shortcutShortLabel="@string/shortcut_search_short"
        android:shortcutLongLabel="@string/shortcut_search_long"
        android:shortcutDisabledMessage="@string/shortcut_disabled">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="io.hearth.mobile"
            android:targetClass="io.hearth.mobile.MainActivity"
            android:data="hearth://search" />
    </shortcut>
    
    <!-- Join Server Shortcut -->
    <shortcut
        android:shortcutId="join_server"
        android:enabled="true"
        android:icon="@drawable/ic_shortcut_add"
        android:shortcutShortLabel="@string/shortcut_join_short"
        android:shortcutLongLabel="@string/shortcut_join_long"
        android:shortcutDisabledMessage="@string/shortcut_disabled">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="io.hearth.mobile"
            android:targetClass="io.hearth.mobile.MainActivity"
            android:data="hearth://server/join" />
    </shortcut>

</shortcuts>
