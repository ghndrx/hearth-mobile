{
  "expo": {
    "name": "Hearth",
    "slug": "hearth-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "hearth",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e1f22"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.hearth.mobile",
      "googleServicesFile": "./GoogleService-Info.plist",
      "associatedDomains": [
        "applinks:hearth.app",
        "applinks:www.hearth.app",
        "applinks:link.hearth.app",
        "activitycontinuation:hearth.app",
        "webcredentials:hearth.app"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Hearth needs camera access to take photos and videos to share in chat.",
        "NSPhotoLibraryUsageDescription": "Hearth needs photo library access to share images in chat.",
        "NSMicrophoneUsageDescription": "Hearth needs microphone access for voice messages and calls.",
        "NSFaceIDUsageDescription": "Hearth uses Face ID for secure authentication.",
        "UIApplicationShortcutItems": [
          {
            "UIApplicationShortcutItemType": "io.hearth.mobile.new_message",
            "UIApplicationShortcutItemTitle": "New Message",
            "UIApplicationShortcutItemSubtitle": "Start a conversation",
            "UIApplicationShortcutItemIconType": "UIApplicationShortcutIconTypeCompose"
          },
          {
            "UIApplicationShortcutItemType": "io.hearth.mobile.search",
            "UIApplicationShortcutItemTitle": "Search",
            "UIApplicationShortcutItemSubtitle": "Find messages & people",
            "UIApplicationShortcutItemIconType": "UIApplicationShortcutIconTypeSearch"
          }
        ],
        "NSUserActivityTypes": [
          "io.hearth.mobile.view-server",
          "io.hearth.mobile.view-channel",
          "io.hearth.mobile.send-message",
          "io.hearth.mobile.start-call",
          "io.hearth.mobile.join-voice",
          "io.hearth.mobile.search",
          "io.hearth.mobile.view-profile"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e1f22"
      },
      "package": "io.hearth.mobile",
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "hearth.app",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "www.hearth.app",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "link.hearth.app",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#5865f2"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Hearth to access your camera for sharing photos and videos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Hearth to access your photos for sharing in chat."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "00000000-0000-0000-0000-000000000000"
      }
    }
  }
}
